{
  "manifest_version": 3,
  "name": "VacationDeals.to — Hidden Resort Rates",
  "version": "2.0.0",
  "description": "See the lowest active vacation package rate for a resort while browsing it on Google. Free, independent, never your data.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://vacationdeals.to/*",
    "https://www.google.com/*",
    "https://www.google.co.uk/*",
    "https://www.google.ca/*",
    "https://www.google.com.au/*",
    "https://maps.google.com/*",
    "https://www.google.com.mx/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com/maps*",
        "https://www.google.co.uk/search*",
        "https://www.google.ca/search*",
        "https://www.google.com.au/search*",
        "https://www.google.com.mx/search*",
        "https://maps.google.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://vacationdeals.to",
  "offline_enabled": false,
  "minimum_chrome_version": "108"
}
