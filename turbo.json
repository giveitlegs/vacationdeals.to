{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "PAYLOAD_SECRET", "RESEND_API_KEY"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:seed-blog": {
      "cache": false
    },
    "scrape": {
      "cache": false
    },
    "seo:audit": {
      "cache": false
    },
    "rss:submit": {
      "cache": false
    }
  }
}
